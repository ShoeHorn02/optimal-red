default_platform(:ios)

# Load .env.local if present (fastlane may not auto-load in all contexts)
env_file = File.join(File.dirname(__FILE__), ".env.local")
if File.exist?(env_file)
  File.readlines(env_file).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    key, val = line.split("=", 2)
    ENV[key] ||= val.to_s.gsub(/^~/, Dir.home) if key
  end
end

platform :ios do
  desc "Increment build number"
  lane :bump_build do
    increment_build_number(xcodeproj: "OptimalRed.xcodeproj")
  end

  desc "Build archive (no upload)"
  lane :build do
    gym(
      project:       "OptimalRed.xcodeproj",
      scheme:        "OptimalRed",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle:      "automatic",
        stripSwiftSymbols: true
      },
      output_directory: "build",
      output_name:      "OptimalRed.ipa",
      clean:            true
    )
    UI.success "✅ Build complete: build/OptimalRed.ipa"
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    bump_build
    build

    key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration:     1200,
      in_house:     false
    )

    upload_to_testflight(
      api_key:                           key,
      ipa:                               "build/OptimalRed.ipa",
      skip_waiting_for_build_processing: true,
      changelog:                         "Latest build from Optimal Red CI"
    )
    UI.success "🚀 Uploaded to TestFlight"
  end
end
